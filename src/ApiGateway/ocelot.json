{
  "Routes": [
    {
      "UpstreamPathTemplate": "/api/v1/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamPathTemplate": "/api/v1/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "auth-service", "Port": 5001 }]
    },
    {
      "UpstreamPathTemplate": "/api/v1/tasks/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamPathTemplate": "/api/v1/tasks/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "task-service", "Port": 5002 }]
    },
    {
      "UpstreamPathTemplate": "/api/v1/tasks",
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "DownstreamPathTemplate": "/api/v1/tasks",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "task-service", "Port": 5002 }]
    },
    {
      "UpstreamPathTemplate": "/api/v1/chat/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamPathTemplate": "/api/v1/chat/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "chat-service", "Port": 5003 }]
    },
    {
      "UpstreamPathTemplate": "/api/v1/notifications/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "DownstreamPathTemplate": "/api/v1/notifications/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "notification-service", "Port": 5004 }]
    },
    {
      "UpstreamPathTemplate": "/api/v1/notifications",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/api/v1/notifications",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "notification-service", "Port": 5004 }]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:8080"
  }
}
